nikita,bf2:EXEC_PATH_DPU=/home/ubuntu/fastclick-dpu

-tom:FASTCLICK_CPUS?=16-31
tom:FASTCLICK_CPUS?=0-23
tom:FASTCLICK_FOLDER_DPU=/home/ubuntu/fastclick_dpu/bin
tom:EXEC_PATH_HOST=/etinfo/users2/tbarbette/workspace/gpu-npf/fastclick/bin/click
tom:EXEC_PATH_DOCA=/etinfo/users2/tyunyayev/Workspace/doca-app-improved/build/doca_gpunetio_simple_receive
