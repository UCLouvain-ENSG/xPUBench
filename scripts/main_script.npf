%info
Main NPF script to rerun the GPU project

%late_variables

//Use default options so we do not force re-run by introducing new variables
GPU_BLOCKING?=false
NB_MBUF?=1000000
NDESC?=2048
TXQ_INLINE?=1
PROFILE?=
TXPARA?=false
TIMER?=1000
gpu-doca:NDESC?=65536

//For CPUFREQ and energy
CPUFREQ_FORCE_RANGE=true
ENERGYDELAY?=0

// Click config files names
cpu,bounce:FILE={dpdk-bounce.click}
gpu-coalescent,bounce:FILE={gpu-bounce-coalescent.click}
gpu-commlist,bounce:FILE={gpu-bounce-commlist.click}
gpu-mw,bounce:FILE={gpu-bounce-mw.click}

cpu,iplookup:FILE={dpdk-iplookup.click}
gpu-coalescent,iplookup:FILE={gpu-iplookup-coalescent.click}
gpu-commlist,iplookup:FILE={gpu-iplookup-commlist.click}
gpu-mw,iplookup:FILE={gpu-iplookup-mw.click}

cpu,crc:FILE={dpdk-crc.click}
gpu-coalescent,crc:FILE={gpu-crc-coalescent.click}
gpu-commlist,crc:FILE={gpu-crc-commlist.click}
gpu-mw,crc:FILE={gpu-crc-mw.click}

USE_GPU=0
gpu-coalescent|gpu-commlist|gpu-mw:USE_GPU=1
GPU=a1:00.0

host:GENERATOR_PORT=EXPAND(${generatordpu:1:pci})
bf2:GENERATOR_PORT_DPU=EXPAND(${generatordpu:0:pci})
bf3:GENERATOR_PORT_DPU=EXPAND(${generatordpu:0:pci})
dpa:GENERATOR_PORT_DPA=EXPAND(${generatordpa:0:pci})


nikita:GENERATOR_LD_LIBRARY_PATH=/etinfo/users2/tyunyayev/Workspace/dpdk-23.03/install_$(hostname)/lib/x86_64-linux-gnu
nikita:GENERATOR_PATH=/etinfo/users2/tyunyayev/Workspace/Pktgen-DPDK/build_$(hostname)/app/pktgen

